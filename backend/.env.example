# =============================================
# TEAMFLOW PORTAL - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# MongoDB Atlas Connection String
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/teamflow?retryWrites=true&w=majority

# JWT Secret - use any long random string
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Port (Railway sets this automatically)
PORT=5000

# Frontend URL for CORS (your Railway domain after deploy)
FRONTEND_URL=https://your-app.railway.app
